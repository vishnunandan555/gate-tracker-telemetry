PORT=3000
NODE_ENV=production

# Use "sqlite" locally and "redis" on Vercel.
DB_PROVIDER=sqlite

# SQLite local file path.
SQLITE_DB_PATH=telemetry.db

# Redis environment variables for Vercel's Redis integration or direct Upstash Redis.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Dashboard access key. This is the key users enter on the landing page.
STATS_API_KEY=developer_super_secret_analytics_token
